#!/usr/bin/expect -f
set timeout 15
spawn ssh -o StrictHostKeyChecking=no root@95.130.227.217
expect "password:"
send "8uwFRcLeJPnzdDH4\r"
expect "*# "
send "cat /etc/nginx/sites-available/perkly.uz || cat /etc/nginx/sites-enabled/default\r"
