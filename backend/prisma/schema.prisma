generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String?
  displayName          String?
  avatarUrl            String?
  role                 String                @default("USER")
  tier                 String                @default("SILVER")
  balance              Int                   @default(0)
  rewardPoints         Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  tokensValidAfter     DateTime?
  telegramId           String?               @unique
  appleSub             String?               @unique
  phone                String?
  deviceToken          String?
  notifyPurchases      Boolean               @default(true)
  notifyMessages       Boolean               @default(true)
  notifyNearby         Boolean               @default(true)
  b2cProfile           B2CProfile?
  ownedCompanies       Company[]             @relation("CompanyOwner")
  savedOffers          SavedOffer[]
  interests            UserInterest[]
  promocodeActivations PromocodeActivation[]
  messagesSent         Message[]             @relation("SenderMessages")
  offersAsSeller       Offer[]               @relation("SellerOffers")
  reviewsWritten       Review[]              @relation("AuthorReviews")
  transactionsAsBuyer  Transaction[]         @relation("BuyerTransactions")
  chatRooms            ChatRoom[]            @relation("ChatParticipants")
  deposits             Deposit[]             @relation("UserDeposits")
  subscriptions        Subscription[]
  squadId              String?
  squad                Squad?                @relation("UserSquad", fields: [squadId], references: [id])
  hasSquadReward       Boolean               @default(false)
  organizedEvents      Event[]               @relation("OrganizerEvents")
  sessions             UserSession[]
  passwordResetCodes   PasswordResetCode[]
  cartItems            CartItem[]
  savedEvents          SavedEvent[]
  financialEntries     FinancialEntry[]
  moderationReports    ModerationReport[]
  moderationAppeals    ModerationAppeal[]
  blocksCreated        UserBlock[]           @relation("UserBlocker")
  blocksReceived       UserBlock[]           @relation("UserBlocked")

  @@index([role])
  @@index([tier])
  @@index([phone])
  @@index([squadId])
  @@index([deletedAt])
}

model PasswordResetCode {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, expiresAt])
}

model UserSession {
  id         String    @id @default(uuid())
  userId     String
  deviceId   String?
  deviceName String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model B2CProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  birthDate   DateTime?
  birthYear   Int?
  gender      String?
  city        String?
  anonymousId String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([anonymousId])
}

model Company {
  id          String      @id @default(uuid())
  ownerUserId String      @unique
  legalName   String
  brandName   String
  inn         String      @unique
  phone       String?
  status      String      @default("PENDING_MODERATION")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  offers      Offer[]
  promocodes  Promocode[]

  @@index([ownerUserId])
  @@index([status])
  @@index([brandName])
}

model Event {
  id                String   @id @default(uuid())
  title             String
  category          String // Festival, Exhibition, Party, etc.
  description       String // Short 2-3 lines
  fullDescription   String? // Long format blog text
  date              DateTime
  startTime         String // e.g. "19:00"
  ageLimit          String   @default("0+")
  location          String // Venue name
  address           String
  latitude          Float?
  longitude         Float?
  imageUrl          String
  viewersCount      Int      @default(0)
  participantsCount Int      @default(0)
  organizerId       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organizer         User     @relation("OrganizerEvents", fields: [organizerId], references: [id])

  @@index([date])
  @@index([category])
  @@index([organizerId])
  @@index([createdAt])
}

// eventId intentionally has no foreign key: the feed also contains stable IDs
// from the external Topka source, not only rows from the Event table.
model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId, createdAt])
  @@index([eventId])
}

model TopkaPost {
  id               String    @id @default(uuid())
  postType         String    @default("event")
  status           String    @default("draft")
  title            String
  subtitle         String?
  description      String
  fullDescription  String?
  category         String
  tags             String    @default("[]")
  badges           String    @default("[]")
  date             DateTime?
  startTime        String?
  endTime          String?
  location         String?
  address          String?
  latitude         Float?
  longitude        Float?
  priceText        String?
  ctaText          String?
  ctaUrl           String?
  priority         Int       @default(0)
  isFeatured       Boolean   @default(false)
  publishAt        DateTime?
  expiresAt        DateTime?
  originalUrl      String?
  poster3x4Url     String?
  story9x16Url     String?
  square1x1Url     String?
  preview16x9Url   String?
  dominantColor    String?
  fallbackGradient String?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, publishAt])
  @@index([postType])
  @@index([category])
  @@index([priority])
}

model Squad {
  id                  String    @id @default(uuid())
  name                String
  inviteCode          String    @unique
  monthlyGoal         Int       @default(1000000)
  rewardTriggeredDate DateTime?
  createdAt           DateTime  @default(now())
  members             User[]    @relation("UserSquad")
}

model Deposit {
  id               String           @id @default(uuid())
  userId           String
  amount           Int
  currency         String           @default("UZS")
  provider         String           @default("CLICK") // CLICK, PAYME, MOCK
  providerId       String?          @unique // Transaction ID from the provider
  idempotencyKey   String?          @unique
  status           String           @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation("UserDeposits", fields: [userId], references: [id])
  financialEntries FinancialEntry[]

  @@index([userId, status])
}

model Offer {
  id                String                @id @default(uuid())
  title             String
  description       String
  price             Int                   @default(0)
  discountPercent   Int?                  @default(0)
  vendorLogo        String?
  imageUrl          String?
  thumbnailUrl      String?
  usageInstructions String?
  category          String
  fulfillmentType   String                @default("INSTRUCTIONS")
  isExclusive       Boolean               @default(false)
  hiddenData        String
  isActive          Boolean               @default(true)
  isFlashDrop       Boolean               @default(false)
  expiresAt         DateTime?
  periodDays        Int                   @default(0)
  latitude          Float?
  longitude         Float?
  sellerId          String
  companyId         String?
  featuredUntil     DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  seller            User                  @relation("SellerOffers", fields: [sellerId], references: [id])
  company           Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  promocodes        Promocode[]
  activations       PromocodeActivation[]
  savedBy           SavedOffer[]
  reviews           Review[]
  transactions      Transaction[]
  cartItems         CartItem[]

  @@index([isActive, isFlashDrop])
  @@index([isActive, expiresAt])
  @@index([sellerId, isActive])
  @@index([companyId, isActive])
  @@index([category])
  @@index([latitude, longitude])
  @@index([featuredUntil])
  @@index([createdAt])
}

model Promocode {
  id             String                @id @default(uuid())
  companyId      String
  offerId        String?
  title          String
  description    String?
  codeType       String                @default("STATIC")
  code           String?
  discountValue  Float
  maxActivations Int?
  perUserLimit   Int                   @default(1)
  validFrom      DateTime?
  validTo        DateTime?
  status         String                @default("ACTIVE")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  offer          Offer?                @relation(fields: [offerId], references: [id], onDelete: SetNull)
  activations    PromocodeActivation[]

  @@index([companyId, status])
  @@index([offerId])
  @@index([codeType])
  @@index([validTo])
  @@index([maxActivations])
}

model PromocodeActivation {
  id           String    @id @default(uuid())
  userId       String
  promocodeId  String
  offerId      String?
  status       String    @default("ISSUED")
  codeSnapshot String?
  copiedAt     DateTime?
  usedAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promocode    Promocode @relation(fields: [promocodeId], references: [id], onDelete: Cascade)
  offer        Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([promocodeId, status])
  @@index([offerId])
  @@index([createdAt])
}

model SavedOffer {
  id        String   @id @default(uuid())
  userId    String
  offerId   String
  source    String   @default("USER")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([userId, createdAt])
  @@index([offerId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  offerId   String
  isGift    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([userId, createdAt])
  @@index([offerId])
}

model UserInterest {
  id        String   @id @default(uuid())
  userId    String
  category  String
  weight    Int      @default(1)
  source    String   @default("ONBOARDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([category])
  @@index([userId])
}

model Transaction {
  id                    String           @id @default(uuid())
  offerId               String
  buyerId               String
  price                 Int
  status                String           @default("PENDING")
  expiresAt             DateTime?
  isGift                Boolean          @default(false)
  giftCode              String?          @unique
  isRedeemed            Boolean          @default(false)
  promocodeActivationId String?
  promocodeDiscount     Int?
  idempotencyKey        String?          @unique
  promocodeCodeSnapshot String?
  buyerComment          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  chatRooms             ChatRoom[]
  dispute               Dispute?
  buyer                 User             @relation("BuyerTransactions", fields: [buyerId], references: [id])
  offer                 Offer            @relation(fields: [offerId], references: [id])
  financialEntries      FinancialEntry[]

  @@index([buyerId, status])
  @@index([buyerId, createdAt])
  @@index([offerId])
  @@index([promocodeActivationId])
  @@index([status, createdAt])
}

model FinancialEntry {
  id             String       @id @default(uuid())
  userId         String
  transactionId  String?
  depositId      String?
  type           String
  amount         Int
  balanceAfter   Int
  currency       String       @default("UZS")
  idempotencyKey String       @unique
  metadata       String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
  deposit        Deposit?     @relation(fields: [depositId], references: [id])

  @@index([userId, createdAt])
  @@index([transactionId])
  @@index([depositId])
  @@index([type, createdAt])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  tier      String
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  comment   String?
  offerId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("AuthorReviews", fields: [authorId], references: [id])
  offer     Offer    @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@index([authorId])
}

model Dispute {
  id            String      @id @default(uuid())
  transactionId String      @unique
  reason        String
  status        String      @default("OPEN")
  resolution    String?
  adminNote     String?
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, createdAt])
  @@index([resolvedBy, resolvedAt])
}

model ChatRoom {
  id            String       @id @default(uuid())
  type          String
  transactionId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  messages      Message[]
  participants  User[]       @relation("ChatParticipants")

  @@index([updatedAt])
  @@index([type, updatedAt])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  roomId    String
  senderId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  sender    User?    @relation("SenderMessages", fields: [senderId], references: [id])
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, isRead])
  @@index([roomId, createdAt])
  @@index([senderId])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model ModerationReport {
  id          String   @id @default(uuid())
  reporterId  String
  targetType  String
  targetId    String
  category    String
  description String
  status      String   @default("OPEN")
  resolution  String?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId, createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model ModerationAppeal {
  id          String   @id @default(uuid())
  userId      String
  subjectType String
  subjectId   String?
  reason      String
  status      String   @default("OPEN")
  resolution  String?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
  @@index([blockedId, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  userId    String?
  sessionId String?
  offerId   String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
}

model DiagnosticIssue {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  kind        String
  message     String
  appVersion  String?
  osVersion   String?
  deviceModel String?
  userId      String?
  breadcrumbs String?
  occurrences Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@index([kind, lastSeenAt])
  @@index([occurrences, lastSeenAt])
}
