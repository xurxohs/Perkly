generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String?
  displayName         String?
  avatarUrl           String?
  role                String        @default("USER")
  tier                String        @default("SILVER")
  balance             Float         @default(0.0)
  rewardPoints        Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  telegramId          String?       @unique
  phone               String?
  messagesSent        Message[]     @relation("SenderMessages")
  offersAsSeller      Offer[]       @relation("SellerOffers")
  reviewsWritten      Review[]      @relation("AuthorReviews")
  transactionsAsBuyer Transaction[] @relation("BuyerTransactions")
  chatRooms           ChatRoom[]    @relation("ChatParticipants")
  deposits            Deposit[]     @relation("UserDeposits")
  subscriptions       Subscription[]
  squadId             String?
  squad               Squad?        @relation("UserSquad", fields: [squadId], references: [id])
  hasSquadReward      Boolean       @default(false)
  organizedEvents     Event[]       @relation("OrganizerEvents")

  @@index([role])
  @@index([tier])
  @@index([squadId])
}

model Event {
  id                String   @id @default(uuid())
  title             String
  category          String   // Festival, Exhibition, Party, etc.
  description       String   // Short 2-3 lines
  fullDescription   String?  // Long format blog text
  date              DateTime
  startTime         String   // e.g. "19:00"
  ageLimit          String   @default("0+")
  location          String   // Venue name
  address           String
  latitude          Float?
  longitude         Float?
  imageUrl          String
  viewersCount      Int      @default(0)
  participantsCount Int      @default(0)
  organizerId       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organizer         User     @relation("OrganizerEvents", fields: [organizerId], references: [id])

  @@index([date])
  @@index([category])
  @@index([organizerId])
}

model TopkaPost {
  id              String   @id @default(uuid())
  postType        String   @default("event")
  status          String   @default("draft")
  title           String
  subtitle        String?
  description     String
  fullDescription String?
  category        String
  tags            String   @default("[]")
  badges          String   @default("[]")
  date            DateTime?
  startTime       String?
  endTime         String?
  location        String?
  address         String?
  latitude        Float?
  longitude       Float?
  priceText       String?
  ctaText         String?
  ctaUrl          String?
  priority        Int      @default(0)
  isFeatured      Boolean  @default(false)
  publishAt       DateTime?
  expiresAt       DateTime?
  originalUrl     String?
  poster3x4Url    String?
  story9x16Url    String?
  square1x1Url    String?
  preview16x9Url  String?
  dominantColor   String?
  fallbackGradient String?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publishAt])
  @@index([postType])
  @@index([category])
  @@index([priority])
}

model Squad {
  id                  String   @id @default(uuid())
  name                String
  inviteCode          String   @unique
  monthlyGoal         Float    @default(1000000.0)
  rewardTriggeredDate DateTime?
  createdAt           DateTime @default(now())
  members             User[]   @relation("UserSquad")
}

model Deposit {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  currency  String   @default("UZS")
  provider  String   @default("MOCK")
  status    String   @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserDeposits", fields: [userId], references: [id])

  @@index([userId, status])
}

model Offer {
  id                String        @id @default(uuid())
  title             String
  description       String
  price             Float         @default(0.0)
  discountPercent   Int?          @default(0)
  vendorLogo        String?
  usageInstructions String?
  category          String
  isExclusive       Boolean       @default(false)
  hiddenData        String
  isActive          Boolean       @default(true)
  isFlashDrop       Boolean       @default(false)
  expiresAt         DateTime?
  periodDays        Int           @default(0)
  latitude          Float?
  longitude         Float?
  sellerId          String
  featuredUntil     DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  seller            User          @relation("SellerOffers", fields: [sellerId], references: [id])
  reviews           Review[]
  transactions      Transaction[]

  @@index([isActive, isFlashDrop])
  @@index([isActive, expiresAt])
  @@index([sellerId, isActive])
  @@index([category])
  @@index([latitude, longitude])
  @@index([featuredUntil])
  @@index([createdAt])
}

model Transaction {
  id        String     @id @default(uuid())
  offerId   String
  buyerId   String
  price         Float
  status        String     @default("PENDING")
  expiresAt     DateTime?
  isGift        Boolean    @default(false)
  giftCode      String?    @unique
  isRedeemed    Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  chatRooms ChatRoom[]
  dispute   Dispute?
  buyer     User       @relation("BuyerTransactions", fields: [buyerId], references: [id])
  offer     Offer      @relation(fields: [offerId], references: [id])

  @@index([buyerId, status])
  @@index([buyerId, createdAt])
  @@index([offerId])
  @@index([status, createdAt])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  tier      String
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  comment   String?
  offerId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("AuthorReviews", fields: [authorId], references: [id])
  offer     Offer    @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@index([authorId])
}

model Dispute {
  id            String      @id @default(uuid())
  transactionId String      @unique
  reason        String
  status        String      @default("OPEN")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model ChatRoom {
  id            String       @id @default(uuid())
  type          String
  transactionId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  messages      Message[]
  participants  User[]       @relation("ChatParticipants")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  roomId    String
  senderId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  sender    User?    @relation("SenderMessages", fields: [senderId], references: [id])
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, isRead])
  @@index([roomId, createdAt])
  @@index([senderId])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  userId    String?
  sessionId String?
  offerId   String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
}
