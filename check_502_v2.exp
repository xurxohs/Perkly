#!/usr/bin/expect -f
set timeout 20
spawn ssh -o StrictHostKeyChecking=no root@95.130.227.217
expect "password:"
send "8uwFRcLeJPnzdDH4\r"
expect "*# "

# Check if port 3000 is listening
send "lsof -i :3000\r"
expect {
    "*# " { }
}

# Check PM2 logs for frontend
send "pm2 logs frontend --lines 50\r"
# Give it some time to output and then Ctrl+C
sleep 5
send "\x03"
expect "*# "

send "exit\r"
expect eof
